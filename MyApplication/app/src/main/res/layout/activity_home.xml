<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Top Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/frame"
            app:title="@string/customer_details"
            app:titleCentered="true"
            app:titleTextColor="@android:color/black"
            app:titleTextAppearance="@style/TextAppearance.AppCompat.Medium">

            <!-- Dev Mode Switch -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchDevMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="12dp"
                app:thumbTint="#D32F2F"
                app:trackTint="#FFCDD2" />

        </com.google.android.material.appbar.MaterialToolbar>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Header Section (Search & Filter) -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <!-- Search Bar -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSearch"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:hint="@string/search"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#D32F2F"
            app:hintTextColor="#D32F2F">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@android:color/black"
                android:textSize="16sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvBrowseLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/browse_by_name"
            android:textColor="#666666"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"/>

        <!-- Alphabet Bar -->
        <HorizontalScrollView
            android:id="@+id/svAlphabetHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clipToPadding="false">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="4dp">

                <!-- All Button -->
                <com.google.android.material.button.MaterialButton 
                    android:id="@+id/btnAll" 
                    style="@style/Widget.MaterialComponents.Button" 
                    android:layout_width="wrap_content" 
                    android:layout_height="48dp" 
                    android:text="All" 
                    android:paddingHorizontal="16dp"
                    android:insetTop="0dp" 
                    android:insetBottom="0dp" 
                    android:minWidth="0dp" 
                    android:minHeight="48dp" 
                    app:backgroundTint="#D32F2F" 
                    android:textColor="@android:color/white" 
                    android:layout_marginEnd="8dp" 
                    app:cornerRadius="24dp"
                    tools:ignore="HardcodedText" />
                
                <!-- A-Z Buttons -->
                <com.google.android.material.button.MaterialButton android:id="@+id/btnA" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="A" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnB" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="B" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnC" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="C" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnD" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="D" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnE" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="E" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnF" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="F" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnG" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="G" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnH" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="H" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnI" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="I" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnJ" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="J" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#a7ee02" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnK" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="K" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnL" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="L" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnM" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="M" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnN" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="N" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnO" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="O" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnP" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="P" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnQ" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="Q" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnR" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="R" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnS" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="S" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnT" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="T" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnU" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="U" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnV" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="V" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnW" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="W" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnX" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="X" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnY" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="Y" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" android:layout_marginEnd="8dp" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnZ" style="@style/Widget.MaterialComponents.Button" android:layout_width="48dp" android:layout_height="48dp" android:text="Z" android:padding="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:minWidth="48dp" android:minHeight="48dp" app:backgroundTint="#D32F2F" android:textColor="@android:color/white" app:cornerRadius="24dp" tools:ignore="HardcodedText"/>
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvCustomerListTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:text="All Customers"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" 
            tools:ignore="HardcodedText"/>
    </LinearLayout>

    <!-- Customer List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCustomers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        tools:listitem="@layout/item_customer" />

    <!-- Navigation Bar -->
    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/reusable_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>